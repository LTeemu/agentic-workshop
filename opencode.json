{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash-free",
  "small_model": "deepseek/deepseek-v4-flash-free",
  "default_agent": "coder",
  "instructions": ["AGENTS.md"],
  "command": {
    "review": {
      "description": "Review code for issues with @reviewer",
      "template": "Run @reviewer on all changed files. Report all issues.",
      "agent": "reviewer"
    },
    "clean": {
      "description": "Refactor code to eliminate duplication",
      "template": "Run @refactor on the codebase to find and eliminate duplicate code patterns.",
      "agent": "refactor"
    },
    "project": {
      "description": "Switch active project or list projects",
      "template": "Read .active-project to see the current project. List all directories in projects/ folder. Ask the user which project to switch to, then set .active-project accordingly."
    },
    "research": {
      "description": "Research a topic using @researcher",
      "template": "Run @researcher on the following topic: <question>",
      "agent": "researcher"
    }
  },
  "plugin": ["./.opencode/plugins/plan-enforcer.js"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "Remove-Item *": "ask",
      "rm *": "ask",
      "git log": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git status": "allow",
      "git add *": "ask",
      "git commit": "ask",
      "git commit *": "ask",
      "git * --amend": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git branch *": "ask",
      "git checkout *": "ask",
      "git stash *": "ask",
      "git tag *": "ask",
      "git revert *": "ask",
      "git rm *": "ask"
    }
  },
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 50000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 5
  }
}
